root = true

# ── Todos los archivos ────────────────────────────────────────────────────────
[*]
charset = utf-8
end_of_line = lf
indent_size = 4
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true

# ── Kotlin ────────────────────────────────────────────────────────────────────
[*.{kt,kts}]
max_line_length = 120

# Las funciones @Composable usan PascalCase por convención de Compose,
# lo que viola la regla estándar de nomenclatura de funciones.
ktlint_function_naming_ignore_when_annotated_with = Composable

# Comas finales en declaraciones y llamadas: producen diffs más limpios
# y permiten reordenar parámetros sin tocar líneas que no cambian.
ij_kotlin_allow_trailing_comma = true
ij_kotlin_allow_trailing_comma_on_call_site = true

# Orden de imports: todos los demás → java/javax → kotlin → aliases.
# Mantiene los imports de plataforma separados de los de la app.
ij_kotlin_imports_layout = *,java.**,javax.**,kotlin.**,^

# ── XML (layouts, manifests, recursos) ────────────────────────────────────────
[*.xml]
indent_size = 4
