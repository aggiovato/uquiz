@startuml ranking-er

!include ../_styles.iuml

title <size:16><b>Ranking Domain</b></size>\n<size:11><color:#60727F>UserRank</color></size>

entity "user_rank" as UserRank <<ranking>> {
    PK(userId)              : TEXT
    ==
    currentRank             : TEXT    NOT NULL
    ..INITIATE|NEOPHYTE|ACOLYTE|DISCIPLE..
    ..ADEPT|VIRTUOSO|ARCHON|PARAGON..
    mmr                     : REAL    NOT NULL  DEFAULT 600.0
    perfEwma                : REAL    NOT NULL  DEFAULT 0.5
    lifetimeCorrect         : INTEGER NOT NULL  DEFAULT 0
    lifetimeIncorrect       : INTEGER NOT NULL  DEFAULT 0
    lifetimeTimeout         : INTEGER NOT NULL  DEFAULT 0
    totalGameAnswers        : INTEGER NOT NULL  DEFAULT 0
    totalStudyAnswers       : INTEGER NOT NULL  DEFAULT 0
    lastRankChangeAt        : INTEGER NULL
    answersSinceRankChange  : INTEGER NOT NULL  DEFAULT 0
    totalXp                 : INTEGER NOT NULL  DEFAULT 0
    createdAt               : INTEGER NOT NULL
    updatedAt               : INTEGER NOT NULL
}

note right of UserRank
  Escala MMR:
  < 400   INITIATE
  < 700   NEOPHYTE
  < 1000  ACOLYTE
  < 1300  DISCIPLE
  < 1650  ADEPT
  < 2000  VIRTUOSO
  < 2500  ARCHON
  >= 2500 PARAGON

  PK = userId (1:1 con UserProfile).
  mmr acumulado por sesion completada.
  perfEwma = media exponencial del
  rendimiento reciente.
  La promocion exige superar
  el umbral del siguiente rango
  + 50 de histeresis.
end note

@enduml
